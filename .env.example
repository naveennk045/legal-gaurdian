# Required — get a key at https://console.groq.com/
GROQ_API_KEY=

# Models (Groq IDs change; check https://console.groq.com/docs/models )
GROQ_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking / retrieval (Ask + build_index only; Risks uses RISK_CHUNK_* below)
CHUNK_SIZE=1500
CHUNK_OVERLAP=150
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.3
MAX_CONTEXT_LENGTH=4000
MAX_TOKENS=1024
TEMPERATURE=0.3
ENABLE_STREAMING=true

# Optional: web augmentation on Ask page (DuckDuckGo; no API key)
# WEB_SEARCH_MAX_RESULTS=5
# Region biases result language (us-en = US English; avoids locale/IP defaulting to Chinese)
# WEB_SEARCH_REGION=us-en

# Risk page: larger slices + batched JSON = faster than one tiny chunk per call
RISK_CHUNK_SIZE=8000
RISK_CHUNK_OVERLAP=200
MAX_RISK_CHUNKS=12
RISK_BATCH_SIZE=3
RISK_MAX_TOKENS=1200
RISK_CHUNK_DELAY_SEC=2.0

# Groq 429 retries (parse "try again in Xs" from API body + min wait)
GROQ_RETRY_MAX_ATTEMPTS=12
GROQ_RETRY_BASE_DELAY=2.0
GROQ_RETRY_MIN_WAIT=5.0
GROQ_RETRY_MAX_DELAY=120.0

# Optional: Google Sheets (Risks page)
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# GOOGLE_SPREADSHEET_ID=
